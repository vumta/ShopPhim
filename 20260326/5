✅ VBA: Enable COM Add-in + trả về kết quả

Public Function EnableCOMAddIn(addinName As String) As String

    On Error GoTo ErrorHandler

    Dim comAddIn As Object
    Dim found As Boolean
    found = False

    For Each comAddIn In Application.COMAddIns
        
        If LCase(comAddIn.Description) Like "*" & LCase(addinName) & "*" _
        Or LCase(comAddIn.ProgId) Like "*" & LCase(addinName) & "*" Then
            
            comAddIn.Connect = True
            found = True
            
            EnableCOMAddIn = "SUCCESS: Enabled COM Add-in -> " & comAddIn.Description
            Exit Function
            
        End If
        
    Next comAddIn

    If Not found Then
        EnableCOMAddIn = "ERROR: COM Add-in not found -> " & addinName
    End If

    Exit Function

ErrorHandler:
    EnableCOMAddIn = "ERROR: " & Err.Description

End Function


