🔥 Version xịn hơn (có check trạng thái trước khi bật)

Public Function EnableCOMAddIn(addinName As String) As String

    On Error GoTo ErrorHandler

    Dim comAddIn As Object

    For Each comAddIn In Application.COMAddIns
        
        If LCase(comAddIn.Description) Like "*" & LCase(addinName) & "*" _
        Or LCase(comAddIn.ProgId) Like "*" & LCase(addinName) & "*" Then
            
            If comAddIn.Connect = True Then
                EnableCOMAddIn = "INFO: Already enabled -> " & comAddIn.Description
            Else
                comAddIn.Connect = True
                EnableCOMAddIn = "SUCCESS: Enabled -> " & comAddIn.Description
            End If
            
            Exit Function
            
        End If
        
    Next comAddIn

    EnableCOMAddIn = "ERROR: Not found -> " & addinName
    Exit Function

ErrorHandler:
    EnableCOMAddIn = "ERROR: " & Err.Number & " - " & Err.Description

End Function


