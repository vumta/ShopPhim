⚡ Version nâng cao (debug cực mạnh)

Bạn nên dùng đoạn này để list toàn bộ COM Add-in (rất hữu ích khi không biết tên đúng):

Public Sub ListCOMAddIns()

    Dim comAddIn As Object
    Dim result As String

    For Each comAddIn In Application.COMAddIns
        result = result & "Description: " & comAddIn.Description & vbCrLf
        result = result & "ProgId: " & comAddIn.ProgId & vbCrLf
        result = result & "Connected: " & comAddIn.Connect & vbCrLf
        result = result & "------------------------" & vbCrLf
    Next comAddIn

    MsgBox result

End Sub


