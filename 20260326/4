Bạn muốn mô phỏng thao tác manual trong Excel:

> File → Options → Add-ins → Manage: COM Add-ins → Go → tick chọn tool



👉 Cái này không dùng Application.AddIns được, vì đó là Excel Add-in (.xlam)
👉 Trường hợp của bạn là COM Add-in → phải dùng COMAddIns


---

✅ VBA: Enable COM Add-in theo tên

Public Sub EnableCOMAddIn(addinName As String)

    Dim comAddIn As Object
    Dim found As Boolean
    found = False

    For Each comAddIn In Application.COMAddIns
        
        ' So sánh theo Description hoặc ProgId
        If LCase(comAddIn.Description) Like "*" & LCase(addinName) & "*" _
        Or LCase(comAddIn.ProgId) Like "*" & LCase(addinName) & "*" Then
            
            comAddIn.Connect = True
            found = True
            Exit For
            
        End If
        
    Next comAddIn

    If Not found Then
        MsgBox "Không tìm thấy COM Add-in: " & addinName, vbCritical
    Else
        MsgBox "Đã bật COM Add-in: " & addinName, vbInformation
    End If

End Sub


