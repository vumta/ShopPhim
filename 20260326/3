🧩 1. VBA: Load Add-in theo tên

Bạn tạo 1 file .bas (hoặc viết trực tiếp trong macro) như sau:

Public Sub LoadAddIn(addinName As String)

    Dim ai As AddIn
    Dim found As Boolean
    found = False

    ' Duyệt tất cả Add-ins
    For Each ai In Application.AddIns
        
        ' So sánh theo tên (có thể là .xlam hoặc tên hiển thị)
        If LCase(ai.Name) = LCase(addinName) Or LCase(ai.Title) = LCase(addinName) Then
            ai.Installed = True
            found = True
            Exit For
        End If
        
    Next ai

    If found = False Then
        MsgBox "Add-in không tồn tại: " & addinName, vbCritical
    Else
        MsgBox "Đã load Add-in: " & addinName, vbInformation
    End If

End Sub


