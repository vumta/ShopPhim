Cập nhật phần lưu file trong function ProcessOneID

Thay đoạn:

wbTemplate.SaveAs outputFolder & "\Template_" & productID & ".xlsx"

bằng đoạn sau.

Dim templateName As String
Dim newFileName As String
Dim timeStr As String

'Tên file template
templateName = wbTemplate.Name

'Tạo timestamp
timeStr = Format(Now, "yymmddhhnnss")

'Replace placeholder
newFileName = Replace(templateName, "ASN_Number", productID)
newFileName = Replace(newFileName, "YYMMDDHHMMSS", timeStr)

'Lưu file
wbTemplate.SaveAs outputFolder & "\" & newFileName


---

Function ProcessOneID hoàn chỉnh sau khi update

Private Function ProcessOneID(productID As String, wsRaw As Worksheet, templatePath As String, outputFolder As String) As Boolean

    Dim wbTemplate As Workbook
    Dim templateName As String
    Dim newFileName As String
    Dim timeStr As String
    
    
    wsRaw.Range("A1").AutoFilter Field:=1, Criteria1:=productID
    
    
    Set wbTemplate = Workbooks.Open(templatePath)
    
    
    Call CopyData(wsRaw, wbTemplate)
    
    
    templateName = wbTemplate.Name
    
    timeStr = Format(Now, "yymmddhhnnss")
    
    newFileName = Replace(templateName, "ASN_Number", productID)
    newFileName = Replace(newFileName, "YYMMDDHHMMSS", timeStr)
    
    
    wbTemplate.SaveAs outputFolder & "\" & newFileName
    
    
    wbTemplate.Close False
    
    
    If wsRaw.FilterMode Then wsRaw.ShowAllData
    
    
    ProcessOneID = True

End Function


