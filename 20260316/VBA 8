Tôi sẽ viết lại toàn bộ code hoàn chỉnh theo đúng yêu cầu của bạn:

PAD gọi 1 macro duy nhất

Truyền vào:

rawFilePath

templatePath

outputFolder


VBA sẽ:

1. Mở raw file


2. Lấy ID unique trong cột A


3. Filter từng ID


4. Gọi function CopyData của bạn (GIỮ NGUYÊN)


5. Save file Template_ID.xlsx


6. Lặp đến khi hết ID




Code dưới đây ổn định khi chạy automation (PAD / UiPath).


---

1. Macro chính để PAD gọi

Public Sub ExportByID(rawFilePath As String, templatePath As String, outputFolder As String)

    Dim wbRaw As Workbook
    Dim wsRaw As Worksheet
    Dim dict As Object
    Dim lastRow As Long
    Dim cell As Range
    Dim id As Variant
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    Application.Calculation = xlCalculationManual
    
    'Mở raw file
    Set wbRaw = Workbooks.Open(rawFilePath)
    Set wsRaw = wbRaw.Sheets(1)
    
    lastRow = wsRaw.Cells(wsRaw.Rows.Count, 1).End(xlUp).Row
    
    'Dictionary lưu ID unique
    Set dict = CreateObject("Scripting.Dictionary")
    
    For Each cell In wsRaw.Range("A2:A" & lastRow)
    
        If Not dict.exists(cell.Value) Then
            dict.Add cell.Value, 1
        End If
        
    Next cell
    
    'Loop từng ID
    For Each id In dict.Keys
    
        Call ProcessOneID(id, wsRaw, templatePath, outputFolder)
        
    Next id
    
    wbRaw.Close False
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    Application.Calculation = xlCalculationAutomatic

End Sub


---

2. Function xử lý từng ID

Private Sub ProcessOneID(productID As String, wsRaw As Worksheet, templatePath As String, outputFolder As String)

    Dim wbTemplate As Workbook
    Dim lastRow As Long
    Dim lastCol As Long
    
    lastRow = wsRaw.Cells(wsRaw.Rows.Count, 1).End(xlUp).Row
    lastCol = wsRaw.Cells(1, wsRaw.Columns.Count).End(xlToLeft).Column
    
    'Filter theo ID
    wsRaw.Range(wsRaw.Cells(1, 1), wsRaw.Cells(lastRow, lastCol)).AutoFilter _
        Field:=1, Criteria1:=productID
    
    'Mở template
    Set wbTemplate = Workbooks.Open(templatePath)
    
    'Gọi function copy của bạn
    Call CopyData(wsRaw, wbTemplate)
    
    'Save file
    wbTemplate.SaveAs outputFolder & "\Template_" & productID & ".xlsx"
    
    wbTemplate.Close False
    
    'Clear filter
    If wsRaw.AutoFilterMode Then
        wsRaw.AutoFilter.ShowAllData
    End If

End Sub


