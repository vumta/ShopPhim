3. Function xử lý từng ID

Private Function ProcessOneID(productID As String, wsRaw As Worksheet, templatePath As String, outputFolder As String) As Boolean

    Dim wbTemplate As Workbook
    
    
    'Filter theo ID
    wsRaw.Range("A1").AutoFilter Field:=1, Criteria1:=productID
    
    
    'Open template
    Set wbTemplate = Workbooks.Open(templatePath)
    
    
    'Gọi function copy của bạn
    Call CopyData(wsRaw, wbTemplate)
    
    
    'Save file
    wbTemplate.SaveAs outputFolder & "\Template_" & productID & ".xlsx"
    
    wbTemplate.Close False
    
    
    wsRaw.AutoFilterMode = False
    
    
    ProcessOneID = True

End Function


