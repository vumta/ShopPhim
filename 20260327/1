⏱️ Hàm Sleep (delay chuẩn cho VBA)

#If VBA7 Then
    Private Declare PtrSafe Sub Sleep Lib "kernel32" (ByVal ms As LongPtr)
#Else
    Private Declare Sub Sleep Lib "kernel32" (ByVal ms As Long)
#End If

Public Sub SleepMilliseconds(ms As Long)
    Sleep ms
End Sub


