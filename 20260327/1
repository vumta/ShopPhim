Chuẩn bài luôn 👍 — .Connect = True/False đôi khi fail ngẫu nhiên (đặc biệt khi chạy bot qua Orchestrator).
Mình nâng cấp cho bạn auto retry + delay + verify sau khi set 👇


---

✅ VBA: Toggle COM Add-in + Auto Retry (chuẩn production)

Public Function ToggleCOMAddIn(addinName As String, isEnable As Boolean, _
                              Optional maxRetry As Integer = 3, _
                              Optional delayMs As Integer = 1000) As String

    On Error GoTo ErrorHandler

    Dim comAddIn As Object
    Dim attempt As Integer
    Dim success As Boolean
    Dim lastError As String

    For Each comAddIn In Application.COMAddIns
        
        If LCase(comAddIn.Description) Like "*" & LCase(addinName) & "*" _
        Or LCase(comAddIn.ProgId) Like "*" & LCase(addinName) & "*" Then
            
            ' Nếu trạng thái đã đúng
            If comAddIn.Connect = isEnable Then
                ToggleCOMAddIn = "STATUS=INFO|ADDIN=" & comAddIn.Description & "|MESSAGE=Already " & IIf(isEnable, "ENABLED", "DISABLED")
                Exit Function
            End If

            ' Retry loop
            For attempt = 1 To maxRetry
                
                On Error Resume Next
                Err.Clear
                
                comAddIn.Connect = isEnable
                
                ' Delay để Excel load Add-in
                Call SleepMilliseconds(delayMs)
                
                ' Verify lại trạng thái
                If Err.Number = 0 And comAddIn.Connect = isEnable Then
                    success = True
                    Exit For
                Else
                    lastError = Err.Number & " - " & Err.Description
                End If
                
                On Error GoTo ErrorHandler
            Next attempt

            ' Kết quả sau retry
            If success Then
                ToggleCOMAddIn = "STATUS=SUCCESS|ADDIN=" & comAddIn.Description & "|ATTEMPT=" & attempt
            Else
                ToggleCOMAddIn = "STATUS=ERROR|ADDIN=" & comAddIn.Description & "|MESSAGE=Failed after " & maxRetry & " retries|LAST_ERROR=" & lastError
            End If

            Exit Function
            
        End If
        
    Next comAddIn

    ToggleCOMAddIn = "STATUS=ERROR|ADDIN=" & addinName & "|MESSAGE=Not found"
    Exit Function

ErrorHandler:
    ToggleCOMAddIn = "STATUS=ERROR|MESSAGE=" & Err.Number & " - " & Err.Description

End Function


