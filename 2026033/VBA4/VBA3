Option Explicit

' ==========================================================================================
' MAIN FUNCTION (CALL FROM PAD)
' ==========================================================================================
Public Function Run_Generate_ByID( _
    ByVal SourcePath As String, _
    ByVal TemplatePath As String, _
    ByVal OutputFolder As String, _
    ByVal ID_ColumnName As String, _
    ByVal ColumnMapping As String, _
    ByVal DefaultMapping As String) As String

    Dim wbSource As Workbook
    Dim wsSource As Worksheet
    Dim lastRow As Long, lastCol As Long
    Dim arrData As Variant
    Dim dictID As Object
    Dim colIndex_ID As Long
    Dim i As Long
    Dim resultLog As String
    
    On Error GoTo ErrorHandler
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' --- Open source ---
    Set wbSource = Workbooks.Open(SourcePath)
    Set wsSource = wbSource.Sheets(1)
    
    lastRow = wsSource.Cells(wsSource.Rows.Count, 1).End(xlUp).Row
    lastCol = wsSource.Cells(1, wsSource.Columns.Count).End(xlToLeft).Column
    
    ' --- Load to Array (FAST) ---
    arrData = wsSource.Range(wsSource.Cells(1, 1), wsSource.Cells(lastRow, lastCol)).Value
    
    ' --- Find ID column ---
    colIndex_ID = FindColumnIndex(arrData, ID_ColumnName)
    If colIndex_ID = 0 Then
        Run_Generate_ByID = "Error|ID column not found"
        GoTo CleanExit
    End If
    
    ' --- Get unique ID ---
    Set dictID = CreateObject("Scripting.Dictionary")
    
    For i = 2 To UBound(arrData, 1)
        If Trim(arrData(i, colIndex_ID)) <> "" Then
            If Not dictID.exists(arrData(i, colIndex_ID)) Then
                dictID.Add arrData(i, colIndex_ID), True
            End If
        End If
    Next i
    
    ' --- Loop each ID ---
    Dim key As Variant
    For Each key In dictID.Keys
        
        Dim newFile As String
        newFile = OutputFolder & "\Report_" & key & "_" & Format(Now, "yymmdd_hhnnss") & ".xlsx"
        
        Process_One_ID arrData, key, colIndex_ID, TemplatePath, newFile, ColumnMapping, DefaultMapping
        
        resultLog = resultLog & key & "#"
        
    Next key
    
    wbSource.Close False
    
    Run_Generate_ByID = "Success|" & resultLog

CleanExit:
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    Exit Function

ErrorHandler:
    Run_Generate_ByID = "Error|" & Err.Description
    Resume CleanExit

End Function


' ==========================================================================================
' PROCESS EACH ID
' ==========================================================================================
Private Sub Process_One_ID( _
    ByVal arrData As Variant, _
    ByVal currentID As String, _
    ByVal colID As Long, _
    ByVal TemplatePath As String, _
    ByVal OutputPath As String, _
    ByVal ColumnMapping As String, _
    ByVal DefaultMapping As String)

    Dim wb As Workbook
    Dim ws As Worksheet
    Dim writeRow As Long
    Dim i As Long
    
    On Error GoTo ErrorHandler
    
    Set wb = Workbooks.Open(TemplatePath)
    Set ws = wb.Sheets(1)
    
    writeRow = 2
    
    ' --- Loop rows ---
    For i = 2 To UBound(arrData, 1)
        
        If Trim(arrData(i, colID)) = currentID Then
            
            CopyRow_ByMapping arrData, ws, i, writeRow, ColumnMapping
            
            writeRow = writeRow + 1
            
        End If
        
    Next i
    
    ' --- Fill default ---
    If writeRow > 2 Then
        Fill_Default ws, writeRow - 1, DefaultMapping
    End If
    
    wb.SaveAs OutputPath
    wb.Close False
    
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Not wb Is Nothing Then wb.Close False

End Sub


' ==========================================================================================
' COPY ROW USING MAPPING
' FORMAT: Name|Index#Name|Index
' ==========================================================================================
Private Sub CopyRow_ByMapping( _
    ByVal arrData As Variant, _
    ByVal wsDest As Worksheet, _
    ByVal sourceRow As Long, _
    ByVal destRow As Long, _
    ByVal ColumnMapping As String)

    Dim arrMap As Variant, pair As Variant
    Dim srcCol As Long, destCol As Long
    Dim colName As String
    Dim i As Long
    
    arrMap = Split(ColumnMapping, "#")
    
    For i = LBound(arrMap) To UBound(arrMap)
        
        If Trim(arrMap(i)) <> "" Then
            
            pair = Split(arrMap(i), "|")
            
            If UBound(pair) = 1 Then
                
                colName = Trim(pair(0))
                destCol = CLng(pair(1))
                
                srcCol = FindColumnIndex(arrData, colName)
                
                If srcCol > 0 Then
                    wsDest.Cells(destRow, destCol).Value = arrData(sourceRow, srcCol)
                End If
                
            End If
            
        End If
        
    Next i

End Sub


' ==========================================================================================
' FILL DEFAULT VALUE
' FORMAT: Index|Value#Index|Value
' ==========================================================================================
Private Sub Fill_Default( _
    ByVal ws As Worksheet, _
    ByVal lastRow As Long, _
    ByVal DefaultMapping As String)

    Dim arrMap As Variant, pair As Variant
    Dim col As Long, val As String
    Dim i As Long
    
    arrMap = Split(DefaultMapping, "#")
    
    For i = LBound(arrMap) To UBound(arrMap)
        
        If Trim(arrMap(i)) <> "" Then
            
            pair = Split(arrMap(i), "|")
            
            If UBound(pair) = 1 Then
                
                col = CLng(pair(0))
                val = pair(1)
                
                ws.Range(ws.Cells(2, col), ws.Cells(lastRow, col)).Value = val
                
            End If
            
        End If
        
    Next i

End Sub


' ==========================================================================================
' FIND COLUMN INDEX BY NAME (FROM ARRAY)
' ==========================================================================================
Private Function FindColumnIndex(arrData As Variant, colName As String) As Long

    Dim j As Long
    
    For j = 1 To UBound(arrData, 2)
        If Trim(arrData(1, j)) = colName Then
            FindColumnIndex = j
            Exit Function
        End If
    Next j
    
    FindColumnIndex = 0

End Function


