🎯 ExportByID (FINAL – STABLE 100%)

Public Function ExportByID(ByVal SourcePath As String, _
                          ByVal TemplatePath As String, _
                          ByVal OutputFolder As String, _
                          ByVal ColumnMapping As String, _
                          ByVal DefaultMapping As String, _
                          ByVal colID As Long) As String

    Dim wbSource As Workbook
    Dim wsRaw As Worksheet
    Dim wsTemp As Worksheet
    
    Dim arrData As Variant
    Dim arrOut() As Variant
    
    Dim lastRow As Long, lastCol As Long
    Dim i As Long, j As Long, outRow As Long
    
    Dim dict As Object
    Dim productID As String
    Dim key As Variant
    
    Dim wbTemp As Workbook
    Dim tempFilePath As String
    Dim workingFile As String
    Dim newFileName As String
    Dim timeStamp As String
    
    On Error GoTo ErrorHandler
    
    ExportByID = "Success"
    
    ' 🚀 Performance
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    Application.Calculation = xlCalculationManual
    
    ' 📂 Open source
    Set wbSource = Workbooks.Open(SourcePath)
    Set wsRaw = wbSource.Sheets(1)
    
    ' 📄 Temp sheet
    Set wsTemp = wbSource.Sheets.Add
    wsTemp.Name = "TEMP_FILTER"
    
    ' 📊 Get data
    lastRow = wsRaw.Cells(wsRaw.Rows.Count, colID).End(xlUp).Row
    lastCol = wsRaw.Cells(1, wsRaw.Columns.Count).End(xlToLeft).Column
    
    arrData = wsRaw.Range(wsRaw.Cells(1, 1), wsRaw.Cells(lastRow, lastCol)).Value
    
    ' 📌 Get unique ID
    Set dict = CreateObject("Scripting.Dictionary")
    
    For i = 2 To lastRow
        productID = Trim(arrData(i, colID))
        If productID <> "" Then
            If Not dict.exists(productID) Then
                dict.Add productID, 1
            End If
        End If
    Next i
    
    ' ================= LOOP =================
    For Each key In dict.Keys
        
        productID = key
        
        ' Reset array
        ReDim arrOut(1 To lastRow, 1 To lastCol)
        
        ' Header
        For j = 1 To lastCol
            arrOut(1, j) = arrData(1, j)
        Next j
        
        outRow = 2
        
        ' Filter in memory
        For i = 2 To lastRow
            If Trim(arrData(i, colID)) = productID Then
                
                For j = 1 To lastCol
                    arrOut(outRow, j) = arrData(i, j)
                Next j
                
                outRow = outRow + 1
            End If
        Next i
        
        If outRow <= 2 Then GoTo NextID
        
        ' ================= TEMP FILE =================
        wsTemp.Cells.Clear
        wsTemp.Range("A1").Resize(outRow - 1, lastCol).Value = arrOut
        
        Set wbTemp = Workbooks.Add
        wsTemp.Copy Before:=wbTemp.Sheets(1)
        
        Application.DisplayAlerts = False
        wbTemp.Sheets(wbTemp.Sheets.Count).Delete
        Application.DisplayAlerts = True
        
        tempFilePath = OutputFolder & "\TEMP_" & productID & ".xlsx"
        wbTemp.SaveAs tempFilePath
        wbTemp.Close False
        Set wbTemp = Nothing
        
        ' ================= WORKING FILE =================
        timeStamp = Format(Now, "yymmddhhnnss")
        
        workingFile = OutputFolder & "\WORK_" & productID & "_" & timeStamp & ".xlsx"
        
        ' 🚨 Clone template (KHÔNG đụng template gốc)
        FileCopy TemplatePath, workingFile
        
        ' ================= PROCESS =================
        Call CopyDataByColumnName(tempFilePath, workingFile, ColumnMapping)
        Call FillDefaultValue(workingFile, DefaultMapping)
        
        ' ================= FINAL FILE =================
        newFileName = Replace(GetFileName(TemplatePath), ".xlsx", "") & _
                      "_" & productID & "_" & timeStamp & ".xlsx"
        
        Name workingFile As OutputFolder & "\" & newFileName
        
        ' ================= CLEAN =================
        On Error Resume Next
        Kill tempFilePath
        On Error GoTo 0
        
NextID:
        
    Next key
    
    wbSource.Close False
    
    GoTo Finalize

' ================= ERROR =================
ErrorHandler:
    ExportByID = "Error: " & Err.Number & " - " & Err.Description

Finalize:
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    Application.Calculation = xlCalculationAutomatic
    
    On Error Resume Next
    
    If Not wbSource Is Nothing Then wbSource.Close False
    If Not wsTemp Is Nothing Then wsTemp.Delete
    
End Function


