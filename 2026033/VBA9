🔥 FUNCTION XỬ LÝ TỪNG ID

Private Sub ProcessOneID(ByVal arrData As Variant, _
                        ByVal productID As String, _
                        ByVal TemplatePath As String, _
                        ByVal OutputFolder As String, _
                        ByVal ColumnMapping As String, _
                        ByVal DefaultMapping As String, _
                        ByVal colID As Long)

    Dim wbTemp As Workbook
    Dim wsTemp As Worksheet
    
    Dim arrOut() As Variant
    Dim i As Long, j As Long
    Dim outRow As Long
    Dim lastCol As Long
    
    Dim tempSource As String
    Dim destFile As String
    Dim timeStamp As String
    
    On Error GoTo ExitSub
    
    lastCol = UBound(arrData, 2)
    
    ReDim arrOut(1 To UBound(arrData, 1), 1 To lastCol)
    
    ' Header
    For j = 1 To lastCol
        arrOut(1, j) = arrData(1, j)
    Next j
    
    outRow = 2
    
    ' Filter data theo ID (IN MEMORY)
    For i = 2 To UBound(arrData, 1)
        If Trim(arrData(i, colID)) = productID Then
            
            For j = 1 To lastCol
                arrOut(outRow, j) = arrData(i, j)
            Next j
            
            outRow = outRow + 1
        End If
    Next i
    
    If outRow <= 2 Then Exit Sub
    
    ' ================= CREATE TEMP SOURCE =================
    Set wbTemp = Workbooks.Add
    Set wsTemp = wbTemp.Sheets(1)
    
    wsTemp.Range("A1").Resize(outRow - 1, lastCol).Value = arrOut
    
    tempSource = OutputFolder & "\TEMP_SRC_" & productID & ".xlsx"
    
    wbTemp.SaveAs tempSource
    wbTemp.Close False
    
    ' ================= CREATE DEST FILE =================
    timeStamp = Format(Now, "yymmddhhnnss")
    
    destFile = OutputFolder & "\Report_" & productID & "_" & timeStamp & ".xlsx"
    
    FileCopy TemplatePath, destFile
    
    ' ================= CALL YOUR FUNCTIONS =================
    Call CopyDataByColumnName(tempSource, destFile, ColumnMapping)
    Call FillDefaultValue(destFile, DefaultMapping)
    
    ' ================= CLEAN =================
    On Error Resume Next
    Kill tempSource
    On Error GoTo 0

ExitSub:
    On Error Resume Next
    If Not wbTemp Is Nothing Then wbTemp.Close False

End Sub


