Public Function ExportByID(ByVal SourcePath As String, _
                          ByVal TemplatePath As String, _
                          ByVal OutputFolder As String, _
                          ByVal ColumnMapping As String, _
                          ByVal DefaultMapping As String, _
                          ByVal colID As Long) As String

    Dim wb As Workbook
    Dim ws As Worksheet
    
    Dim arr As Variant
    Dim dict As Object
    
    Dim lastRow As Long, lastCol As Long
    Dim i As Long
    Dim productID As String
    
    On Error GoTo ErrorHandler
    
    ExportByID = "Success"
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    Application.Calculation = xlCalculationManual
    
    ' Open source
    Set wb = Workbooks.Open(SourcePath)
    Set ws = wb.Sheets(1)
    
    lastRow = ws.Cells(ws.Rows.Count, colID).End(xlUp).Row
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    
    arr = ws.Range(ws.Cells(1, 1), ws.Cells(lastRow, lastCol)).Value
    
    ' Get unique ID
    Set dict = CreateObject("Scripting.Dictionary")
    
    For i = 2 To lastRow
        productID = Trim(arr(i, colID))
        If productID <> "" Then
            If Not dict.exists(productID) Then
                dict.Add productID, 1
            End If
        End If
    Next i
    
    ' LOOP từng ID
    Dim key As Variant
    For Each key In dict.Keys
        
        Call ProcessOneID(arr, key, TemplatePath, OutputFolder, ColumnMapping, DefaultMapping, colID)
        
        DoEvents
        
    Next key
    
    wb.Close False
    
    GoTo Finalize

ErrorHandler:
    ExportByID = "Error: " & Err.Description

Finalize:
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    Application.Calculation = xlCalculationAutomatic

End Function


