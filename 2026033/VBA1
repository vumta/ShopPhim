2. XỬ LÝ TỪNG ID (KEY FIX)

Private Sub ProcessSingleID( _
    ByVal productID As String, _
    ByVal wsRaw As Worksheet, _
    ByVal TemplatePath As String, _
    ByVal OutputFolder As String, _
    ByVal CopyMapping As String, _
    ByVal DefaultMapping As String)

    Dim wbTemp As Workbook
    Dim wsTemp As Worksheet
    Dim tempPath As String
    Dim destPath As String
    Dim lastRow As Long
    Dim lastCol As Long
    
    lastRow = wsRaw.Cells(wsRaw.Rows.Count, 1).End(xlUp).Row
    lastCol = wsRaw.Cells(1, wsRaw.Columns.Count).End(xlToLeft).Column
    
    'Create temp workbook (ONLY this ID)
    Set wbTemp = Workbooks.Add
    Set wsTemp = wbTemp.Sheets(1)
    
    'Copy header
    wsRaw.Rows(1).Copy wsTemp.Rows(1)
    
    'Filter by ID using AdvancedFilter (NO BUG)
    wsRaw.Range(wsRaw.Cells(1, 1), wsRaw.Cells(lastRow, lastCol)).AdvancedFilter _
        Action:=xlFilterCopy, _
        CriteriaRange:=CreateCriteria(wsRaw, productID), _
        CopyToRange:=wsTemp.Range("A1"), _
        Unique:=False
    
    'Save temp file
    tempPath = Environ("TEMP") & "\TEMP_" & productID & ".xlsx"
    wbTemp.SaveAs tempPath
    wbTemp.Close False
    
    'Create output file path
    destPath = OutputFolder & "\Template_" & productID & ".xlsx"
    
    'Copy template to new file
    FileCopy TemplatePath, destPath
    
    '🚀 CALL YOUR EXISTING FUNCTIONS
    Call CopyDataByColumnName(tempPath, destPath, CopyMapping)
    
    If InStr(1, DefaultMapping, "|") > 0 Then
        Call FillDefaultValue(destPath, DefaultMapping)
    End If
    
    'Delete temp file
    Kill tempPath

End Sub


