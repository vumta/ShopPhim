🔥 GIẢI PHÁP CHUẨN NHẤT CHO CODE CỦA BẠN

👉 Tôi viết thêm 1 function:

ExportByID_WithYourFunctions

Không đụng CopyDataByColumnName

Không đụng FillDefaultValue

Chỉ tạo file tạm theo từng ID



---

1. FUNCTION CHÍNH (PAD CALL)

Public Function ExportByID_WithYourFunctions( _
    ByVal SourcePath As String, _
    ByVal TemplatePath As String, _
    ByVal OutputFolder As String, _
    ByVal CopyMapping As String, _
    ByVal DefaultMapping As String) As String

    Dim wbRaw As Workbook
    Dim wsRaw As Worksheet
    Dim dict As Object
    Dim lastRow As Long
    Dim cell As Range
    Dim id As Variant
    
    ExportByID_WithYourFunctions = "Success"
    
    On Error GoTo ErrorHandler
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    Set wbRaw = Workbooks.Open(SourcePath)
    Set wsRaw = wbRaw.Sheets(1)
    
    lastRow = wsRaw.Cells(wsRaw.Rows.Count, 1).End(xlUp).Row
    
    Set dict = CreateObject("Scripting.Dictionary")
    
    'Get unique IDs
    For Each cell In wsRaw.Range("A2:A" & lastRow)
        If Not dict.exists(cell.Value) Then
            dict.Add cell.Value, 1
        End If
    Next cell
    
    'Loop each ID
    For Each id In dict.Keys
    
        Call ProcessSingleID( _
            id, wsRaw, TemplatePath, OutputFolder, CopyMapping, DefaultMapping)
        
    Next id
    
    wbRaw.Close False
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    Exit Function

ErrorHandler:
    ExportByID_WithYourFunctions = "Error: " & Err.Description
End Function


