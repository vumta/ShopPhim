3. FUNCTION TẠO CRITERIA

Private Function CreateCriteria(ws As Worksheet, productID As String) As Range

    Dim wsCriteria As Worksheet
    
    Set wsCriteria = ws.Parent.Sheets.Add
    
    wsCriteria.Range("A1").Value = ws.Range("A1").Value
    wsCriteria.Range("A2").Value = productID
    
    Set CreateCriteria = wsCriteria.Range("A1:A2")

End Function


