Option Explicit

' ==========================================================================================
' MAIN ENTRY FOR PAD
' ==========================================================================================
Public Function Run_GenerateFiles_ByID( _
    ByVal SourcePath As String, _
    ByVal TemplatePath As String, _
    ByVal OutputFolder As String, _
    ByVal ID_ColumnIndex As Long) As String

    Dim wbSource As Workbook
    Dim wsSource As Worksheet
    Dim lastRow As Long
    Dim dict As Object
    Dim i As Long
    Dim ID_Value As String
    
    Dim resultLog As String
    
    On Error GoTo ErrorHandler
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' --- Open source file ONCE ---
    Set wbSource = Workbooks.Open(SourcePath)
    Set wsSource = wbSource.Sheets(1)
    
    lastRow = wsSource.Cells(wsSource.Rows.Count, ID_ColumnIndex).End(xlUp).Row
    
    ' --- Get unique IDs ---
    Set dict = CreateObject("Scripting.Dictionary")
    
    For i = 2 To lastRow
        ID_Value = Trim(wsSource.Cells(i, ID_ColumnIndex).Value)
        If ID_Value <> "" Then
            If Not dict.exists(ID_Value) Then
                dict.Add ID_Value, ID_Value
            End If
        End If
    Next i
    
    ' --- Loop each ID ---
    Dim key As Variant
    For Each key In dict.Keys
        
        Dim newFilePath As String
        
        newFilePath = OutputFolder & "\" & _
                      "Report_" & key & "_" & Format(Now, "yymmdd_hhnnss") & ".xlsx"
        
        ' --- Process ONE ID ---
        Process_One_ID wsSource, key, ID_ColumnIndex, TemplatePath, newFilePath
        
        resultLog = resultLog & "Done ID: " & key & vbCrLf
    Next key
    
    wbSource.Close False
    
    Run_GenerateFiles_ByID = "Success|" & resultLog
    
CleanExit:
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    Exit Function

ErrorHandler:
    Run_GenerateFiles_ByID = "Error|" & Err.Description
    Resume CleanExit
    
End Function


' ==========================================================================================
' PROCESS EACH ID (CRITICAL FIX HERE)
