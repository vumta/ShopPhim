Private Sub Process_One_ID( _
    ByVal wsSource As Worksheet, _
    ByVal CurrentID As String, _
    ByVal ID_ColumnIndex As Long, _
    ByVal TemplatePath As String, _
    ByVal OutputPath As String)

    Dim wbTemp As Workbook
    Dim wsTemp As Worksheet
    
    Dim lastRow As Long
    Dim i As Long
    Dim writeRow As Long
    
    On Error GoTo ErrorHandler
    
    ' --- Open template ---
    Set wbTemp = Workbooks.Open(TemplatePath)
    Set wsTemp = wbTemp.Sheets(1)
    
    lastRow = wsSource.Cells(wsSource.Rows.Count, ID_ColumnIndex).End(xlUp).Row
    
    writeRow = 2 ' Start writing from row 2
    
    ' ======================================================================================
    ' 🔥 CRITICAL FIX: ONLY COPY ROWS MATCHING CURRENT ID
    ' ======================================================================================
    For i = 2 To lastRow
        
        If Trim(wsSource.Cells(i, ID_ColumnIndex).Value) = CurrentID Then
            
            ' 👉 CALL YOUR EXISTING COMPLEX COPY FUNCTION HERE
            Call CopyRow_Custom(wsSource, wsTemp, i, writeRow)
            
            writeRow = writeRow + 1
        End If
        
    Next i
    
    ' --- Save file ---
    wbTemp.SaveAs OutputPath
    wbTemp.Close False
    
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Not wbTemp Is Nothing Then wbTemp.Close False
End Sub


