✅ VBA: Enable / Disable COM Add-in (dynamic)

Public Function ToggleCOMAddIn(addinName As String, isEnable As Boolean) As String

    On Error GoTo ErrorHandler

    Dim comAddIn As Object

    For Each comAddIn In Application.COMAddIns
        
        If LCase(comAddIn.Description) Like "*" & LCase(addinName) & "*" _
        Or LCase(comAddIn.ProgId) Like "*" & LCase(addinName) & "*" Then
            
            ' Nếu trạng thái đã đúng rồi
            If comAddIn.Connect = isEnable Then
                
                If isEnable Then
                    ToggleCOMAddIn = "INFO: Already ENABLED -> " & comAddIn.Description
                Else
                    ToggleCOMAddIn = "INFO: Already DISABLED -> " & comAddIn.Description
                End If
                
            Else
                ' Thực hiện bật/tắt
                comAddIn.Connect = isEnable
                
                If isEnable Then
                    ToggleCOMAddIn = "SUCCESS: ENABLED -> " & comAddIn.Description
                Else
                    ToggleCOMAddIn = "SUCCESS: DISABLED -> " & comAddIn.Description
                End If
                
            End If
            
            Exit Function
            
        End If
        
    Next comAddIn

    ToggleCOMAddIn = "ERROR: Not found -> " & addinName
    Exit Function

ErrorHandler:
    ToggleCOMAddIn = "ERROR: " & Err.Number & " - " & Err.Description

End Function


