🔥 Version PRO (chuẩn cho production – dễ parse log)

Nếu bạn muốn parse dễ hơn trong UiPath:

Public Function ToggleCOMAddIn(addinName As String, isEnable As Boolean) As String

    On Error GoTo ErrorHandler

    Dim comAddIn As Object
    Dim status As String
    Dim message As String

    For Each comAddIn In Application.COMAddIns
        
        If LCase(comAddIn.Description) Like "*" & LCase(addinName) & "*" _
        Or LCase(comAddIn.ProgId) Like "*" & LCase(addinName) & "*" Then
            
            If comAddIn.Connect = isEnable Then
                status = "INFO"
                message = "Already " & IIf(isEnable, "ENABLED", "DISABLED")
            Else
                comAddIn.Connect = isEnable
                status = "SUCCESS"
                message = IIf(isEnable, "ENABLED", "DISABLED")
            End If
            
            ToggleCOMAddIn = "STATUS=" & status & "|ADDIN=" & comAddIn.Description & "|MESSAGE=" & message
            Exit Function
            
        End If
        
    Next comAddIn

    ToggleCOMAddIn = "STATUS=ERROR|ADDIN=" & addinName & "|MESSAGE=Not found"
    Exit Function

ErrorHandler:
    ToggleCOMAddIn = "STATUS=ERROR|MESSAGE=" & Err.Number & " - " & Err.Description

End Function


