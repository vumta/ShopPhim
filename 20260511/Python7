if __name__ == "__main__":
    # ĐIỀN THÔNG TIN THỰC TẾ CỦA BẠN VÀO ĐÂY ĐỂ CHẠY THỬ
    
    # Kể cả khi bạn vô tình dán đường dẫn có dấu \ thì hàm main_process sẽ tự động xử lý
    TEST_FOLDER_PATH = r"C:\Users\xxxxx\Desktop\Data\WorkOrderReport" 
    TEST_SHEET_NAMES = "Report" 
    TEST_TABLE_ID = "Work_Order_Report_rpa" # Thêm project.dataset phía trước nếu cần
    TEST_CREDENTIALS = r"C:\path\to\your\api-key.json" # Đường dẫn file JSON của bạn

    print("--- BẮT ĐẦU CHẠY THỬ NGHIỆM ---")
    print(f"Thư mục Data gốc: {TEST_FOLDER_PATH}")
    print(f"Bảng BigQuery: {TEST_TABLE_ID}")
    print("Đang xử lý dữ liệu, vui lòng đợi...\n")

    # 1. Gọi hàm chính
    result = main_process(
        folder_path=TEST_FOLDER_PATH, 
        sheet_names_str=TEST_SHEET_NAMES, 
        table_id=TEST_TABLE_ID, 
        credentials_path=TEST_CREDENTIALS
    )

    # 2. Gọi hàm SELECT kiểm tra nếu Insert thành công
    if result == "Success":
        # Do TEST_CREDENTIALS ở đây chưa được replace (chỉ replace bên trong main_process)
        # Nên ta dùng lại path.replace để truyền vào hàm verify cho an toàn
        safe_credentials = TEST_CREDENTIALS.replace('\\', '/') if TEST_CREDENTIALS else None
        verify_inserted_data(table_id=TEST_TABLE_ID, credentials_path=safe_credentials)

    print("\n--- KẾT THÚC ---")
    print(f"Kết quả trả về: {result}")

