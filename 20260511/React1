const categories = ["Tất cả", ...new Set(interviewData.map(item => item.category))];

const App = () => {
  const [viewMode, setViewMode] = useState('flashcard');
  const [currentCategory, setCurrentCategory] = useState("Tất cả");
  const [currentIndex, setCurrentIndex] = useState(0);
  const [isFlipped, setIsFlipped] = useState(false);

  const filteredData = interviewData.filter(
    item => currentCategory === "Tất cả" || item.category === currentCategory
  );

  const handleNext = () => {
    setIsFlipped(false);
    setTimeout(() => {
      setCurrentIndex((prev) => (prev + 1) % filteredData.length);
    }, 150);
  };

  const handlePrev = () => {
    setIsFlipped(false);
    setTimeout(() => {
      setCurrentIndex((prev) => (prev - 1 + filteredData.length) % filteredData.length);
    }, 150);
  };

  const handleCategoryChange = (cat) => {
    setCurrentCategory(cat);
    setCurrentIndex(0);
    setIsFlipped(false);
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans selection:bg-blue-200">
      <header className="bg-blue-800 text-white shadow-md p-6 border-b-4 border-blue-600">
        <div className="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-3">
            <BookOpen size={32} className="text-blue-200" />
            <div>
              <h1 className="text-2xl font-bold">Hành trang Phỏng vấn CMC Global</h1>
              <p className="text-blue-200 text-sm">Vị trí: RPA / Power Platform Developer</p>
            </div>
          </div>
          <div className="flex bg-blue-900 p-1 rounded-lg">
            <button 
              onClick={() => setViewMode('flashcard')}
              className={`flex items-center gap-2 px-4 py-2 rounded-md text-sm font-medium transition-colors ${viewMode === 'flashcard' ? 'bg-white text-blue-800 shadow' : 'text-blue-100 hover:bg-blue-700'}`}
            >
              <LayoutGrid size={16} /> Thẻ ghi nhớ
            </button>
            <button 
              onClick={() => setViewMode('list')}
              className={`flex items-center gap-2 px-4 py-2 rounded-md text-sm font-medium transition-colors ${viewMode === 'list' ? 'bg-white text-blue-800 shadow' : 'text-blue-100 hover:bg-blue-700'}`}
            >
              <List size={16} /> Danh sách
            </button>
          </div>
        </div>
      </header>

      <main className="max-w-4xl mx-auto p-4 md:p-6 pb-20">
        
        <div className="flex flex-wrap gap-2 mb-8">
          {categories.map(cat => (
            <button
              key={cat}
              onClick={() => handleCategoryChange(cat)}
              className={`px-4 py-2 rounded-full text-sm font-semibold transition-all ${currentCategory === cat ? 'bg-blue-600 text-white shadow-md scale-105' : 'bg-white text-slate-600 border border-slate-200 hover:border-blue-300 hover:bg-blue-50'}`}
            >
              {cat}
            </button>
          ))}
        </div>

        {viewMode === 'flashcard' && (
          <div className="flex flex-col items-center w-full animate-in fade-in duration-500">
            <div className="mb-4 text-slate-500 font-medium">
              Câu {currentIndex + 1} / {filteredData.length}
            </div>

            <div 
              className="w-full max-w-2xl min-h-[380px] perspective-1000 cursor-pointer group"
              onClick={() => setIsFlipped(!isFlipped)}
            >
              <div className={`relative w-full h-full min-h-[380px] transition-all duration-500 transform-style-preserve-3d shadow-xl rounded-2xl ${isFlipped ? 'rotate-y-180' : ''}`}>
                
                <div className={`absolute inset-0 w-full h-full bg-white rounded-2xl p-8 flex flex-col items-center justify-center text-center backface-hidden border-t-4 border-blue-500 ${isFlipped ? 'invisible' : 'visible'}`}>
                  <span className="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-bold mb-6 tracking-wider uppercase">
                    {filteredData[currentIndex].category}
                  </span>
                  <h2 className="text-2xl md:text-3xl font-bold text-slate-800 leading-snug">
                    {filteredData[currentIndex].question}
                  </h2>
                  <div className="absolute bottom-6 flex items-center gap-2 text-slate-400 text-sm font-medium animate-pulse">
                    <RotateCcw size={16} /> Chạm vào thẻ để xem đáp án
                  </div>
                </div>

                <div className={`absolute inset-0 w-full h-full bg-slate-800 text-white rounded-2xl p-6 md:p-8 flex flex-col justify-center backface-hidden rotate-y-180 overflow-y-auto border-t-4 border-emerald-500 ${!isFlipped ? 'invisible' : 'visible'}`}>
                  <h3 className="text-emerald-400 font-semibold mb-4 text-lg flex items-center gap-2">
                    <CheckCircle2 size={20} /> Gợi ý trả lời (Từ khóa quan trọng):
                  </h3>
                  <p className="text-lg md:text-xl leading-relaxed text-slate-100 mb-6 font-light">
                    {filteredData[currentIndex].answer}
                  </p>
                  
                  {filteredData[currentIndex].tip && (
                    <div className="mt-auto bg-slate-700/80 p-4 rounded-xl border border-slate-600 flex items-start gap-3">
                      <Lightbulb size={24} className="text-yellow-400 shrink-0 mt-1" />
                      <div>
                        <p className="text-sm font-bold text-yellow-400 mb-1">Mẹo ghi điểm cực mạnh</p>
                        <p className="text-sm text-slate-300">{filteredData[currentIndex].tip}</p>
                      </div>
                    </div>
                  )}
                </div>

              </div>
            </div>

            <div className="flex items-center gap-6 mt-8">
              <button 
                onClick={handlePrev}
                className="p-4 rounded-full bg-white text-blue-600 shadow-md hover:bg-blue-50 hover:scale-110 transition-all border border-slate-100"
              >
                <ChevronLeft size={28} />
              </button>
              
              <button 
                onClick={() => setIsFlipped(!isFlipped)}
                className="px-8 py-3 bg-blue-600 text-white font-bold rounded-full shadow-lg hover:bg-blue-700 hover:shadow-xl transition-all flex items-center gap-2 active:scale-95"
              >
                <RotateCcw size={20} />
                Lật thẻ
              </button>

              <button 
                onClick={handleNext}
                className="p-4 rounded-full bg-white text-blue-600 shadow-md hover:bg-blue-50 hover:scale-110 transition-all border border-slate-100"
              >
                <ChevronRight size={28} />
              </button>
            </div>
          </div>
        )}

        {viewMode === 'list' && (
          <div className="flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-4 duration-500">
            {filteredData.map((item, idx) => (
              <div key={idx} className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-md transition-shadow">
                <div className="p-5 md:p-6 border-b border-slate-100 bg-slate-50/50">
                  <span className="text-xs font-bold text-blue-600 mb-2 block uppercase tracking-wider">{item.category}</span>
                  <h2 className="text-xl font-bold text-slate-800">{item.question}</h2>
                </div>
                <div className="p-5 md:p-6">
                  <p className="text-slate-700 text-lg leading-relaxed mb-4">{item.answer}</p>
                  {item.tip && (
                    <div className="bg-yellow-50 text-yellow-800 p-4 rounded-lg flex gap-3 items-start border border-yellow-100">
                      <Lightbulb size={20} className="text-yellow-600 shrink-0 mt-0.5" />
                      <p className="text-sm font-medium">{item.tip}</p>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}

      </main>

      <style dangerouslySetInnerHTML={{__html: `
        .perspective-1000 { perspective: 1000px; }
        .transform-style-preserve-3d { transform-style: preserve-3d; }
        .backface-hidden { backface-visibility: hidden; }
        .rotate-y-180 { transform: rotateY(180deg); }
      `}} />
    </div>
  );
};

export default App;


```
