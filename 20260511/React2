Code C#:
public bool IsPalindrome(string s) {
    int left = 0, right = s.Length - 1;
    while(left < right) {
        if(!char.IsLetterOrDigit(s[left])) left++;
        else if(!char.IsLetterOrDigit(s[right])) right--;
        else if(char.ToLower(s[left]) != char.ToLower(s[right])) 
            return false;
        else { left++; right--; }
    }
    return true;
}`,
