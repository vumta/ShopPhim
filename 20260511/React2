Code C#:
public int MostFrequent(int[] nums) {
    var dict = new Dictionary<int, int>();
    int maxCount = 0, res = nums[0];
    
    foreach(int n in nums) {
        if(!dict.ContainsKey(n)) dict[n] = 0;
        dict[n]++;
        
        if(dict[n] > maxCount) { 
            maxCount = dict[n]; 
            res = n; 
        }
    }
